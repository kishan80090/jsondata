          src: url('https://s.pinimg.com/webapp/Pin-Sans-MacOS-Heavy-2b6abf8c.woff2') format('woff2');
          font-weight: 800;
          
        }

        body, button, input, select, textarea {
          font-family: var(--base-font-family-default-latin) !important;
        }

